@prefix : <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#> .

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1> rdf:type owl:Ontology ;
                                                                     owl:imports <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2001/XMLSchema#maxExclusive
xsd:maxExclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#maxInclusive
xsd:maxInclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#minExclusive
xsd:minExclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#minInclusive
xsd:minInclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#qualifiedCardinality
owl:qualifiedCardinality rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/hosts
<http://www.w3.org/ns/sosa/hosts> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/observes
<http://www.w3.org/ns/sosa/observes> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/forProperty
<http://www.w3.org/ns/ssn/forProperty> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/hasInput
<http://www.w3.org/ns/ssn/hasInput> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/hasOutput
<http://www.w3.org/ns/ssn/hasOutput> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/implements
<http://www.w3.org/ns/ssn/implements> rdf:type owl:AnnotationProperty .


#################################################################
#    Individuals
#################################################################

###  AverageTemperature
:AverageTemperature rdf:type owl:NamedIndividual ,
                             <http://www.w3.org/ns/ssn/Output> ,
                             <http://www.w3.org/ns/ssn/Property> ;
                    <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  AverageTemperatureSoftSensor
:AverageTemperatureSoftSensor rdf:type owl:NamedIndividual ,
                                       <http://www.w3.org/ns/sosa/Sensor> ;
                              <http://www.w3.org/ns/ssn/implements> :AverageTemperatureSoftSensorProcedure .


###  AverageTemperatureSoftSensorProcedure
:AverageTemperatureSoftSensorProcedure rdf:type owl:NamedIndividual ,
                                                <http://www.w3.org/ns/sosa/Procedure> ;
                                       <http://www.w3.org/ns/ssn/hasInput> :DecreasedTemperature ,
                                                                           :IncreasedTemperature ;
                                       <http://www.w3.org/ns/ssn/hasOutput> :AverageTemperature .


###  DecreaseTemperatureSoftSensor
:DecreaseTemperatureSoftSensor rdf:type owl:NamedIndividual ,
                                        <http://www.w3.org/ns/sosa/Sensor> ;
                               <http://www.w3.org/ns/ssn/implements> :DecreaseTemperatureSoftSensorProcedure .


###  DecreaseTemperatureSoftSensorProcedure
:DecreaseTemperatureSoftSensorProcedure rdf:type owl:NamedIndividual ,
                                                 <http://www.w3.org/ns/sosa/Procedure> ;
                                        <http://www.w3.org/ns/ssn/hasInput> :TemperatureSensor1MeasuredTemperature ,
                                                                            :TemperatureSensor2MeasuredTemperature ;
                                        <http://www.w3.org/ns/ssn/hasOutput> :DecreasedTemperature .


###  DecreasedTemperature
:DecreasedTemperature rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/ns/ssn/Input> ,
                               <http://www.w3.org/ns/ssn/Output> ,
                               <http://www.w3.org/ns/ssn/Property> ;
                      <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  Dehumidifier
:Dehumidifier rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/ns/sosa/Actuator> ;
              rdfs:seeAlso <http://www.semanticweb.org/rayan/ontologies/2025/ha#switch_dehumidifier> ;
              rdfs:label "Dehumidifier (HA: switch.dehumidifier)"^^xsd:string ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts> :EnergyConsumptionIncrease ,
                                                                                               :RoomHumidityDecrease ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState> "0"^^xsd:int ,
                                                                                                         "1"^^xsd:int .


