@prefix : <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#> .

# Namespace raccourci pour les entites Home Assistant de Rayan
@prefix ha: <http://www.semanticweb.org/rayan/ontologies/2025/ha#> .

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1> rdf:type owl:Ontology ;
                                                                     owl:imports <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2001/XMLSchema#maxExclusive
xsd:maxExclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#maxInclusive
xsd:maxInclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#minExclusive
xsd:minExclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#minInclusive
xsd:minInclusive rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#qualifiedCardinality
owl:qualifiedCardinality rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/hosts
<http://www.w3.org/ns/sosa/hosts> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/observes
<http://www.w3.org/ns/sosa/observes> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/forProperty
<http://www.w3.org/ns/ssn/forProperty> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/hasInput
<http://www.w3.org/ns/ssn/hasInput> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/hasOutput
<http://www.w3.org/ns/ssn/hasOutput> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/ssn/implements
<http://www.w3.org/ns/ssn/implements> rdf:type owl:AnnotationProperty .


#################################################################
#    Individuals
#################################################################

###  AverageTemperature
# Valeur moyenne calculee entre Sensor1 et Sensor2 : (14.0 + 14.0) / 2 = 14.0 => sous le seuil optimal de 18°C
:AverageTemperature rdf:type owl:NamedIndividual ,
                             <http://www.w3.org/ns/ssn/Output> ,
                             <http://www.w3.org/ns/ssn/Property> ;
                    <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  AverageTemperatureSoftSensor
:AverageTemperatureSoftSensor rdf:type owl:NamedIndividual ,
                                       <http://www.w3.org/ns/sosa/Sensor> ;
                              <http://www.w3.org/ns/ssn/implements> :AverageTemperatureSoftSensorProcedure .


###  AverageTemperatureSoftSensorProcedure
:AverageTemperatureSoftSensorProcedure rdf:type owl:NamedIndividual ,
                                                <http://www.w3.org/ns/sosa/Procedure> ;
                                       <http://www.w3.org/ns/ssn/hasInput> :DecreasedTemperature ,
                                                                           :IncreasedTemperature ;
                                       <http://www.w3.org/ns/ssn/hasOutput> :AverageTemperature .


###  DecreaseTemperatureSoftSensor
:DecreaseTemperatureSoftSensor rdf:type owl:NamedIndividual ,
                                        <http://www.w3.org/ns/sosa/Sensor> ;
                               <http://www.w3.org/ns/ssn/implements> :DecreaseTemperatureSoftSensorProcedure .


###  DecreaseTemperatureSoftSensorProcedure
:DecreaseTemperatureSoftSensorProcedure rdf:type owl:NamedIndividual ,
                                                 <http://www.w3.org/ns/sosa/Procedure> ;
                                        <http://www.w3.org/ns/ssn/hasInput> :TemperatureSensor1MeasuredTemperature ,
                                                                            :TemperatureSensor2MeasuredTemperature ;
                                        <http://www.w3.org/ns/ssn/hasOutput> :DecreasedTemperature .


###  DecreasedTemperature
# Valeur sous le seuil optimal => le moteur doit inferer qu'il faut chauffer
:DecreasedTemperature rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/ns/ssn/Input> ,
                               <http://www.w3.org/ns/ssn/Output> ,
                               <http://www.w3.org/ns/ssn/Property> ;
                      <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  Dehumidifier
# Lie a l'entite HA : switch.dehumidifier
:Dehumidifier rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/ns/sosa/Actuator> ;
              rdfs:seeAlso ha:entity/switch/dehumidifier ;
              rdfs:label "Dehumidifier (HA: switch.dehumidifier)" ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts> :EnergyConsumptionIncrease ,
                                                                                               :RoomHumidityDecrease ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState> "0"^^xsd:int ,
                                                                                                         "1"^^xsd:int .


###  EnergyConsumption
:EnergyConsumption rdf:type owl:NamedIndividual ,
                            <http://www.w3.org/ns/sosa/ObservableProperty> ;
                   <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "0.0"^^xsd:double .


###  EnergyConsumptionDecrease
:EnergyConsumptionDecrease rdf:type owl:NamedIndividual ,
                                    <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange> ;
                           <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith> <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease> ;
                           <http://www.w3.org/ns/ssn/forProperty> :EnergyConsumption .


###  EnergyConsumptionIncrease
:EnergyConsumptionIncrease rdf:type owl:NamedIndividual ,
                                    <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange> ;
                           <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith> <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease> ;
                           <http://www.w3.org/ns/ssn/forProperty> :EnergyConsumption .


###  EnergyConsumptionMeter
# Lie a l'entite HA : sensor.power_consumption
:EnergyConsumptionMeter rdf:type owl:NamedIndividual ,
                                 <http://www.w3.org/ns/sosa/Sensor> ;
                        rdfs:seeAlso ha:entity/sensor/power_consumption ;
                        rdfs:label "Energy Meter (HA: sensor.power_consumption)" ;
                        <http://www.w3.org/ns/sosa/observes> :EnergyConsumption ;
                        <http://www.w3.org/ns/ssn/implements> :EnergyConsumptionMeterProcedure .


###  EnergyConsumptionMeterMeasuredEnergyConsumption
:EnergyConsumptionMeterMeasuredEnergyConsumption rdf:type owl:NamedIndividual ,
                                                          <http://www.w3.org/ns/ssn/Output> ,
                                                          <http://www.w3.org/ns/ssn/Property> ;
                                                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "0.0"^^xsd:double .


###  EnergyConsumptionMeterProcedure
:EnergyConsumptionMeterProcedure rdf:type owl:NamedIndividual ,
                                          <http://www.w3.org/ns/sosa/Procedure> ;
                                 <http://www.w3.org/ns/ssn/hasOutput> :EnergyConsumptionMeterMeasuredEnergyConsumption .


###  FloorHeating
# Lie a l'entite HA : switch.office_floor_heating (l'actionneur que le moteur doit activer si T < 18°C)
:FloorHeating rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/ns/sosa/Actuator> ;
              rdfs:seeAlso ha:entity/switch/office_floor_heating ;
              rdfs:label "Floor Heating (HA: switch.office_floor_heating)" ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts> :EnergyConsumptionIncrease ,
                                                                                               :RoomTemperatureIncrease ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState> "0"^^xsd:int ,
                                                                                                         "1"^^xsd:int .


###  Heater
# Lie a l'entite HA : climate.hvac
:Heater rdf:type owl:NamedIndividual ,
                 <http://www.w3.org/ns/sosa/Actuator> ;
        rdfs:seeAlso ha:entity/climate/hvac ;
        rdfs:label "Heater (HA: climate.hvac)" ;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts> :EnergyConsumptionIncrease ,
                                                                                         :RoomTemperatureIncrease ;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState> "0"^^xsd:int ,
                                                                                                   "1"^^xsd:int ,
                                                                                                   "2"^^xsd:int .


###  HumiditySensor
# Lie a l'entite HA : sensor.outside_humidity (ou remplace par ton capteur d'humidite bureau si tu en as un)
:HumiditySensor rdf:type owl:NamedIndividual ,
                         <http://www.w3.org/ns/sosa/Sensor> ;
                rdfs:seeAlso ha:entity/sensor/outside_humidity ;
                rdfs:label "Humidity Sensor (HA: sensor.outside_humidity)" ;
                <http://www.w3.org/ns/sosa/observes> :RoomHumidity ;
                <http://www.w3.org/ns/ssn/implements> :HumiditySensorProcedure .


###  HumiditySensorMeasuredHumidity
# Valeur d'humidite actuelle (sous le seuil de 30%) => le moteur detects que l'humidite est trop basse
:HumiditySensorMeasuredHumidity rdf:type owl:NamedIndividual ,
                                         <http://www.w3.org/ns/ssn/Output> ,
                                         <http://www.w3.org/ns/ssn/Property> ;
                                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "8.065931477520403"^^xsd:double .


###  HumiditySensorProcedure
:HumiditySensorProcedure rdf:type owl:NamedIndividual ,
                                  <http://www.w3.org/ns/sosa/Procedure> ;
                         <http://www.w3.org/ns/ssn/hasOutput> :HumiditySensorMeasuredHumidity .


###  IncreaseTemperatureSoftSensor
:IncreaseTemperatureSoftSensor rdf:type owl:NamedIndividual ,
                                        <http://www.w3.org/ns/sosa/Sensor> ;
                               <http://www.w3.org/ns/ssn/implements> :IncreaseTemperatureSoftSensorProcedure .


###  IncreaseTemperatureSoftSensorProcedure
:IncreaseTemperatureSoftSensorProcedure rdf:type owl:NamedIndividual ,
                                                 <http://www.w3.org/ns/sosa/Procedure> ;
                                        <http://www.w3.org/ns/ssn/hasInput> :TemperatureSensor1MeasuredTemperature ,
                                                                            :TemperatureSensor2MeasuredTemperature ;
                                        <http://www.w3.org/ns/ssn/hasOutput> :IncreasedTemperature .


###  IncreasedTemperature
:IncreasedTemperature rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/ns/ssn/Input> ,
                               <http://www.w3.org/ns/ssn/Output> ,
                               <http://www.w3.org/ns/ssn/Property> ;
                      <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  Motion
# Lie a l'entite HA : binary_sensor.office_motion — valeur "true" = mouvement detecte => la condition de temperature est active
:Motion rdf:type owl:NamedIndividual ,
                 <http://www.w3.org/ns/sosa/ObservableProperty> ;
        rdfs:seeAlso ha:entity/binary_sensor/office_motion ;
        rdfs:label "Motion (HA: binary_sensor.office_motion)" ;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "true"^^xsd:boolean .


###  MotionActivated
:MotionActivated rdf:type owl:NamedIndividual ,
                          <http://www.w3.org/ns/ssn/Property> ;
                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "true"^^xsd:boolean .


###  MotionSensor
# Lie a l'entite HA : binary_sensor.office_motion
:MotionSensor rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/ns/sosa/Sensor> ;
              rdfs:seeAlso ha:entity/binary_sensor/office_motion ;
              rdfs:label "Motion Sensor (HA: binary_sensor.office_motion)" ;
              <http://www.w3.org/ns/sosa/observes> :Motion ;
              <http://www.w3.org/ns/ssn/implements> :MotionSensorProcedure .


###  MotionSensorMeasuredMotion
# true = mouvement detecte dans le bureau => la condition optimale de temperature est active
:MotionSensorMeasuredMotion rdf:type owl:NamedIndividual ,
                                     <http://www.w3.org/ns/ssn/Output> ,
                                     <http://www.w3.org/ns/ssn/Property> ;
                            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "true"^^xsd:boolean .


###  MotionSensorProcedure
:MotionSensorProcedure rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/ns/sosa/Procedure> ;
                       <http://www.w3.org/ns/ssn/hasOutput> :MotionSensorMeasuredMotion .


###  OfficeHumidityLowerLimit
# Seuil bas d'humidite : 30% => en dessous le Dehumidifier ne doit pas tourner
:OfficeHumidityLowerLimit rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/ns/ssn/Property> ;
                          <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "30.0"^^xsd:double .


###  OfficeHumidityOptimalCondition
:OfficeHumidityOptimalCondition rdf:type owl:NamedIndividual ,
                                         <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition> ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThanOrEqualTo> ;
                                                                                owl:hasValue :OfficeHumidityLowerLimit
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThanOrEqualTo> ;
                                                                                owl:hasValue :OfficeHumidityUpperLimit
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                         ] ;
                                <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity ;
                                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable> "true"^^xsd:boolean ;
                                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/satisfiedBy> "0001-01-01T09:00:00Z"^^xsd:dateTimeStamp .


###  OfficeHumidityUpperLimit
# Seuil haut d'humidite : 50%
:OfficeHumidityUpperLimit rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/ns/ssn/Property> ;
                          <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "50.0"^^xsd:double .


###  OfficeTemperatureLowerLimit
# Seuil bas de temperature : 18°C => en dessous FloorHeating doit etre active
:OfficeTemperatureLowerLimit rdf:type owl:NamedIndividual ,
                                      <http://www.w3.org/ns/ssn/Property> ;
                             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "18.0"^^xsd:double .


###  OfficeTemperatureOptimalCondition
:OfficeTemperatureOptimalCondition rdf:type owl:NamedIndividual ,
                                            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition> ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThan> ;
                                                                                   owl:hasValue :OfficeTemperatureLowerLimit
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThanOrEqualTo> ;
                                                                                   owl:hasValue :OfficeTemperatureUpperLimit
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ]
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnablingConstraint> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/equalTo> ;
                                                            owl:hasValue :MotionActivated
                                                          ]
                                            ] ;
                                   <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/forEnablingProperty> :Motion ;
                                   <http://www.w3.org/ns/ssn/forProperty> :RoomTemperature ;
                                   <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable> "true"^^xsd:boolean .


###  OfficeTemperatureUpperLimit
# Seuil haut de temperature : 22°C => au dessus le chauffage doit s'arreter
:OfficeTemperatureUpperLimit rdf:type owl:NamedIndividual ,
                                      <http://www.w3.org/ns/ssn/Property> ;
                             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "22.0"^^xsd:double .


###  RoomHumidity
# Humidite actuelle de la piece : 8% => SOUS le seuil de 30% => condition d'humidite NON satisfaite
:RoomHumidity rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/ns/sosa/ObservableProperty> ;
              <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "8.065931477520403"^^xsd:double .


###  RoomHumidityDecrease
:RoomHumidityDecrease rdf:type owl:NamedIndividual ,
                               <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange> ;
                      <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith> <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease> ;
                      <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity .


###  RoomM370
# La piece bureau — heberge tous les capteurs et actionneurs
# MotionSensor ajoute car il conditionne l'activation de la condition de temperature
:RoomM370 rdf:type owl:NamedIndividual ,
                   <http://www.w3.org/ns/sosa/Platform> ;
          rdfs:label "Bureau M370 (Home Assistant)" ;
          <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationModel> :RoomM370FMU ;
          <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/minimizes> :EnergyConsumption ;
          <http://www.w3.org/ns/sosa/hosts> :Dehumidifier ,
                                            :EnergyConsumptionMeter ,
                                            :FloorHeating ,
                                            :Heater ,
                                            :HumiditySensor ,
                                            :MotionSensor ,
                                            :TemperatureSensor1 ,
                                            :TemperatureSensor2 ;
          <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/generateCombinationsOnlyFromOptimalConditions> "false"^^xsd:boolean .


###  RoomM370FMU
:RoomM370FMU rdf:type owl:NamedIndividual ,
                      <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/FmuModel> ;
             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationFidelitySeconds> "100"^^xsd:int ;
             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasURI> "roomM370.fmu"^^xsd:anyURI .


###  RoomTemperature
# Temperature actuelle de la piece : 14°C => SOUS le seuil de 18°C => le moteur doit inferer FloorHeating = ON
:RoomTemperature rdf:type owl:NamedIndividual ,
                          <http://www.w3.org/ns/sosa/ObservableProperty> ;
                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  RoomTemperatureIncrease
:RoomTemperatureIncrease rdf:type owl:NamedIndividual ,
                                  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange> ;
                         <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith> <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease> ;
                         <http://www.w3.org/ns/ssn/forProperty> :RoomTemperature .


###  RoomTemperatureLowerLimit1
:RoomTemperatureLowerLimit1 rdf:type owl:NamedIndividual ,
                                     <http://www.w3.org/ns/ssn/Property> ;
                            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "27.5"^^xsd:double .


###  RoomTemperatureUpperLimit1
:RoomTemperatureUpperLimit1 rdf:type owl:NamedIndividual ,
                                     <http://www.w3.org/ns/ssn/Property> ;
                            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "30.2"^^xsd:double .


###  TemperatureSensor1
# Lie a l'entite HA : sensor.office_temperature_sensor_1 (raw = input_number.office_temperature_sensor_1_raw)
:TemperatureSensor1 rdf:type owl:NamedIndividual ,
                             <http://www.w3.org/ns/sosa/Sensor> ;
                    rdfs:seeAlso ha:entity/sensor/office_temperature_sensor_1 ;
                    rdfs:label "Temperature Sensor 1 (HA: sensor.office_temperature_sensor_1)" ;
                    <http://www.w3.org/ns/sosa/observes> :RoomTemperature ;
                    <http://www.w3.org/ns/ssn/implements> :TemperatureSensor1Procedure .


###  TemperatureSensor1MeasuredTemperature
# Valeur lue depuis HA : 14°C => SOUS le seuil optimal de 18°C => FloorHeating doit etre active
:TemperatureSensor1MeasuredTemperature rdf:type owl:NamedIndividual ,
                                                <http://www.w3.org/ns/ssn/Input> ,
                                                <http://www.w3.org/ns/ssn/Output> ,
                                                <http://www.w3.org/ns/ssn/Property> ;
                                       <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


###  TemperatureSensor1Procedure
:TemperatureSensor1Procedure rdf:type owl:NamedIndividual ,
                                      <http://www.w3.org/ns/sosa/Procedure> ;
                             <http://www.w3.org/ns/ssn/hasOutput> :TemperatureSensor1MeasuredTemperature .


###  TemperatureSensor2
# Lie a l'entite HA : sensor.office_temperature_sensor_2 (raw = input_number.office_temperature_sensor_2_raw)
:TemperatureSensor2 rdf:type owl:NamedIndividual ,
                             <http://www.w3.org/ns/sosa/Sensor> ;
                    rdfs:seeAlso ha:entity/sensor/office_temperature_sensor_2 ;
                    rdfs:label "Temperature Sensor 2 (HA: sensor.office_temperature_sensor_2)" ;
                    <http://www.w3.org/ns/sosa/observes> :RoomTemperature ;
                    <http://www.w3.org/ns/ssn/implements> :TemperatureSensor2Procedure .


###  TemperatureSensor2MeasuredTemperature
# Valeur lue depuis HA : 14°C => meme valeur que Sensor1 pour ce test
:TemperatureSensor2MeasuredTemperature rdf:type owl:NamedIndividual ,
                                                <http://www.w3.org/ns/ssn/Input> ,
                                                <http://www.w3.org/ns/ssn/Output> ,
                                                <http://www.w3.org/ns/ssn/Property> ;
                                       <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "14.0"^^xsd:double .


