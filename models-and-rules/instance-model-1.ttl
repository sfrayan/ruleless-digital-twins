        rdfs:seeAlso <http://www.semanticweb.org/rayan/ontologies/2025/ha#binary_sensor_office_motion> ;
        rdfs:label "Motion (HA: binary_sensor.office_motion)"^^xsd:string ;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "true"^^xsd:boolean .


###  MotionActivated
:MotionActivated rdf:type owl:NamedIndividual ,
                          <http://www.w3.org/ns/ssn/Property> ;
                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "true"^^xsd:boolean .


